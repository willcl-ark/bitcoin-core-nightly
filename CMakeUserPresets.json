{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "darwin",
      "inherits": "default",
      "cacheVariables": {
        "WITH_USDT": "OFF"
      }
    },
    {
      "name": "strict-align-ubsan",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_GUI": "OFF",
        "REDUCE_EXPORTS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "SANITIZERS": "undefined,float-divide-by-zero",
        "APPEND_CXXFLAGS": "-mstrict-align -fno-omit-frame-pointer"
      }
    }
  ]
}
