{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "darwin",
      "inherits": "default",
      "cacheVariables": {
        "WITH_USDT": "OFF"
      }
    },
    {
      "name": "darwin-x86_64",
      "inherits": "darwin",
      "cacheVariables": {
        "CMAKE_C_ARCHIVE_FINISH": "<CMAKE_RANLIB> -no_warning_for_no_symbols <TARGET>",
        "CMAKE_CXX_ARCHIVE_FINISH": "<CMAKE_RANLIB> -no_warning_for_no_symbols <TARGET>"
      }
    },
    {
      "name": "strict-align-ubsan",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_GUI": "OFF",
        "REDUCE_EXPORTS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "SANITIZERS": "undefined,float-divide-by-zero",
        "APPEND_CXXFLAGS": "-mstrict-align -fno-omit-frame-pointer"
      }
    }
  ]
}
